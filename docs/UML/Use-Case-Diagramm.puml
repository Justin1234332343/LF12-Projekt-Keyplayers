@startuml Use-Case-Diagramm
title Use-Case-Diagramm - LF12 Keyplayers

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle stickman

actor "Mitarbeiter" as Mitarbeiter
actor "Ollama LLM" as Ollama <<external>>
actor "Oracle DB / ORDS" as DB <<external>>

rectangle "Schulungs-Organisations-Tool" {

  ' --- Dashboard ---
  usecase "Dashboard anzeigen" as UC_Dashboard

  ' --- Firmen ---
  usecase "Firmen auflisten" as UC_FirmenList
  usecase "Firma anlegen\n(mit Ansprechpartner)" as UC_FirmaCreate
  usecase "Firma bearbeiten" as UC_FirmaEdit
  usecase "Firma löschen" as UC_FirmaDelete

  ' --- Kurse ---
  usecase "Kurse auflisten" as UC_KurseList
  usecase "Kurs anlegen\n(mit Terminen)" as UC_KursCreate
  usecase "Kursdetails ansehen\n(Termine + Agenda)" as UC_KursDetail

  ' --- Teilnehmer ---
  usecase "Teilnehmer auflisten" as UC_TeilnList
  usecase "Teilnehmer anlegen" as UC_TeilnCreate
  usecase "Teilnehmer-Status\nändern" as UC_TeilnStatus

  ' --- Angebote ---
  usecase "Angebote auflisten" as UC_AngebotList
  usecase "Angebot anlegen" as UC_AngebotCreate
  usecase "Angebot annehmen\n/ ablehnen" as UC_AngebotStatus
  usecase "Rechnung erzeugen" as UC_RechnungAuto

  ' --- Rechnungen ---
  usecase "Rechnungen auflisten" as UC_RechnungList
  usecase "Zahlung erfassen" as UC_Zahlung
  usecase "Rechnung als\nbezahlt markieren" as UC_RechnungBezahlt

  ' --- KI ---
  usecase "Angebotstext\ngenerieren" as UC_KIAngebot
  usecase "Kursbeschreibung\ngenerieren" as UC_KIKurs
  usecase "Mahnung\ngenerieren" as UC_KIMahnung

  ' --- Includes (Auto-Workflows) ---
  UC_AngebotStatus .> UC_RechnungAuto : <<include>>\n(bei "angenommen")
  UC_Zahlung .> UC_RechnungBezahlt : <<include>>\n(wenn voll bezahlt)
}

' --- Mitarbeiter -> Use Cases ---
Mitarbeiter --> UC_Dashboard

Mitarbeiter --> UC_FirmenList
Mitarbeiter --> UC_FirmaCreate
Mitarbeiter --> UC_FirmaEdit
Mitarbeiter --> UC_FirmaDelete

Mitarbeiter --> UC_KurseList
Mitarbeiter --> UC_KursCreate
Mitarbeiter --> UC_KursDetail

Mitarbeiter --> UC_TeilnList
Mitarbeiter --> UC_TeilnCreate
Mitarbeiter --> UC_TeilnStatus

Mitarbeiter --> UC_AngebotList
Mitarbeiter --> UC_AngebotCreate
Mitarbeiter --> UC_AngebotStatus

Mitarbeiter --> UC_RechnungList
Mitarbeiter --> UC_Zahlung

Mitarbeiter --> UC_KIAngebot
Mitarbeiter --> UC_KIKurs
Mitarbeiter --> UC_KIMahnung

' --- Externe Akteure ---
UC_KIAngebot --> Ollama
UC_KIKurs --> Ollama
UC_KIMahnung --> Ollama

UC_FirmaCreate --> DB
UC_KursCreate --> DB
UC_AngebotStatus --> DB
UC_Zahlung --> DB
UC_TeilnStatus --> DB

@enduml
