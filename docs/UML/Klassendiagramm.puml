@startuml Klassendiagramm
title Klassendiagramm - LF12 Keyplayers (Python FastAPI Backend)

skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

' ==========================================
' ============   API LAYER   ===============
' ==========================================
package "main (FastAPI)" {
  class FastAPIApp <<Application>> {
    + app : FastAPI
    - ords : OrdsService
    - ollama : OllamaService
    --
    + health() : dict
    .. Firmen ..
    + list_firmen() : list
    + get_firma(firma_id: int) : dict
    + create_firma_komplett(body: FirmaKomplettRequest) : dict
    + update_firma(firma_id: int, body: dict) : dict
    + delete_firma(firma_id: int) : None
    .. Kurse ..
    + list_kurse() : list
    + get_kurs(kurs_id: int) : dict
    + get_kurs_detail(kurs_id: int) : dict
    + create_kurs_komplett(body: KursKomplettRequest) : dict
    .. Teilnehmer ..
    + list_teilnehmer() : list
    + create_teilnehmer(body: TeilnehmerRequest) : dict
    + update_teilnehmer_status(id: int, body: TeilnehmerStatusRequest) : dict
    .. Angebote ..
    + list_angebote() : list
    + create_angebot(body: AngebotRequest) : dict
    + update_angebot_status(id: int, body: AngebotStatusRequest) : dict
    .. Rechnungen ..
    + list_rechnungen() : list
    + zahlung_erfassen(nr: int, body: ZahlungRequest) : dict
    .. Ollama ..
    + ollama_health() : dict
    + ollama_angebot_text(body) : dict
    + ollama_kurs_beschreibung(body) : dict
    + ollama_mahnung(body) : dict
  }
}

' ==========================================
' ==========  PYDANTIC SCHEMAS  ============
' ==========================================
package "Schemas (Pydantic)" {
  class FirmaKomplettRequest <<DTO>> {
    + firma_name : str
    + rechnungsadresse : str
    + email_rechnungsversand : str
    + kommentar : str?
    + ap_vorname : str
    + ap_nachname : str
    + ap_email : str
    + ap_telefon : str?
    + ap_position : str?
  }

  class KursKomplettRequest <<DTO>> {
    + kurs_name : str
    + kurs_typ : str
    + kurs_ort : str?
    + kurs_datum_beginn : str
    + kurs_datum_ende : str
    + kurs_zeitraum : str
    + kurs_tage : int
    + seminaragenda_id : int?
    + termine : list[dict]
  }

  class TeilnehmerRequest <<DTO>> {
    + firma_id : int
    + vorname : str
    + nachname : str
    + email : str
  }

  class TeilnehmerStatusRequest <<DTO>> {
    + status_id : int
  }

  class AngebotRequest <<DTO>> {
    + firma_id : int
    + kurs_id : int
    + angebot_betrag : float
  }

  class AngebotStatusRequest <<DTO>> {
    + status : str
    + zahltermin_tage : int?
  }

  class ZahlungRequest <<DTO>> {
    + betrag : float
    + zahlungsmethode : str
  }
}

' ==========================================
' ==========  SERVICE LAYER  ===============
' ==========================================
package "Services" {
  class OrdsService <<Service>> {
    - base_url : str
    - timeout : float
    - session : requests.Session
    --
    .. internal ..
    - _url(path: str) : str
    - _handle(resp: Response) : Any
    - _get(path: str, params: dict?) : Any
    - _post(path: str, payload: dict) : Any
    - _put(path: str, payload: dict) : Any
    - _delete(path: str) : Any
    .. Firmen ..
    + list_firmen() : list
    + get_firma(firma_id: int) : dict
    + create_firma_komplett(payload: dict) : dict
    + update_firma(firma_id: int, payload: dict) : dict
    + delete_firma(firma_id: int) : None
    + list_ansprechpartner(firma_id: int) : list
    .. Kurse ..
    + list_kurse() : list
    + get_kurs(kurs_id: int) : dict
    + get_kurs_detail(kurs_id: int) : dict
    + create_kurs_komplett(payload: dict) : dict
    .. Teilnehmer ..
    + list_teilnehmer() : list
    + create_teilnehmer(payload: dict) : dict
    + update_teilnehmer_status(id: int, status_id: int) : dict
    .. Angebote / Rechnungen ..
    + list_angebote() : list
    + create_angebot(payload: dict) : dict
    + update_angebot_status(id: int, status: str, tage: int) : dict
    + list_rechnungen() : list
    + zahlung_erfassen(nr: int, betrag: float, methode: str) : dict
  }

  class OllamaService <<Service>> {
    - base_url : str
    + model : str
    - timeout : float
    - session : requests.Session
    --
    - _url(path: str) : str
    - _check_model_ready(resp: Response) : None
    + is_available() : bool
    + list_models() : list[str]
    + generate(prompt: str, model: str?) : str
    + chat(messages: list[dict], model: str?) : str
    .. Business Prompts ..
    + generate_angebot_text(firma, kurs, datum, betrag) : str
    + generate_kurs_beschreibung(name, typ, tage) : str
    + generate_mahnung(firma, rechnung, betrag, termin, stufe) : str
    + generate_benachrichtigung(empfaenger, typ, kontext) : str
  }

  class "build_ords_service()" as buildOrds <<Factory>> {
    + ORDS_BASE_URL : env
    + ORDS_TIMEOUT : env
  }

  class "build_ollama_service()" as buildOllama <<Factory>> {
    + OLLAMA_BASE_URL : env
    + OLLAMA_MODEL : env
    + OLLAMA_TIMEOUT : env
  }
}

' ==========================================
' =======  EXTERNAL SYSTEMS  ===============
' ==========================================
package "External" {
  class "ORDS REST API" as ORDS <<External>> {
    .. auto-REST ..
    GET/POST /firma/
    GET/PUT/DELETE /firma/:id
    GET/POST /teilnehmer/
    GET/POST /kurs/
    .. custom Modul lf12.v1 ..
    POST /api/v1/firmen/komplett/
    POST /api/v1/kurse/komplett/
    GET  /api/v1/kurse/:id/detail
    PUT  /api/v1/angebote/:id/status
    POST /api/v1/rechnungen/:nr/zahlung/
    PUT  /api/v1/teilnehmer/:id/status
  }

  class "Ollama LLM" as Ollama <<External>> {
    POST /api/generate
    POST /api/chat
    GET  /api/tags
    --
    Modell: mistral
  }
}

' ==========================================
' ==========  RELATIONSHIPS  ===============
' ==========================================
FastAPIApp ..> OrdsService : delegiert CRUD
FastAPIApp ..> OllamaService : delegiert KI

FastAPIApp ..> FirmaKomplettRequest : nutzt
FastAPIApp ..> KursKomplettRequest : nutzt
FastAPIApp ..> TeilnehmerRequest : nutzt
FastAPIApp ..> TeilnehmerStatusRequest : nutzt
FastAPIApp ..> AngebotRequest : nutzt
FastAPIApp ..> AngebotStatusRequest : nutzt
FastAPIApp ..> ZahlungRequest : nutzt

buildOrds ..> OrdsService : << creates >>
buildOllama ..> OllamaService : << creates >>

OrdsService --> ORDS : HTTP/JSON
OllamaService --> Ollama : HTTP/JSON

note right of FastAPIApp
  CORS: erlaubt alle Origins
  Module-level Singletons:
    ords, ollama
end note

note right of OrdsService
  Fehler-Mapping:
   - HTTPError -> HTTPException(status)
   - ConnectionError -> 502
end note

note right of OllamaService
  Fehler-Mapping:
   - 404 (Modell laedt) -> 503
   - andere Fehler -> 502
end note

@enduml